# Standard Node.js ignore
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# IDE settings
.vscode/
.idea/

# Backend specific (mirroring backend/.gitignore)
backend/uploads/
backend/node_modules/
backend/.env

# Frontend specific (mirroring frontend/.gitignore)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/*.tsbuildinfo
frontend/next-env.d.ts
